{
  "name": "zxbasic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "zmakebas": "./dist-cli/zmakebas.js"
  },
  "scripts": {
    "dev": "vite --config vite.web.config.ts",
    "build": "npm run build:web && npm run build:cli",
    "build:web": "tsc -b && vite build --config vite.web.config.ts",
    "build:cli": "vite build --config vite.cli.config.ts",
    "build:exe": "npm run build:cli && node build-exe.mjs",
    "cli": "tsx src/cli/zmakebas.ts",
    "lint": "eslint .",
    "preview": "vite preview --config vite.web.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "bootstrap": "^5.3.8",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "assemblyscript": "^0.19.6",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsspeccy": "^3.2.0",
    "sass": "^1.101.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.1.0"
  }
}
